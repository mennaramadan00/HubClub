@model IEnumerable<HubClub.Models.UserPackage>
@{
    ViewData["Title"] = "الإدارة الشاملة للباقات";
}

<div dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 style="color: var(--sapphire); font-weight: 800; margin: 0;">الإدارة الشاملة للباقات</h2>
            <p style="color: var(--text-slate); margin: 0;">عرض وتعديل أرصدة باقات المشتركين في النظام</p>
        </div>
        <a asp-action="Buy" class="btn-aurelian-primary">
            شحن باقة جديدة
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-glass mb-4" style="border-right-color: #10b981; color: #047857;">
            <strong>نجاح:</strong> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-glass mb-4" style="border-right-color: #ef4444; color: #ef4444;">
            <strong>خطأ:</strong> @TempData["Error"]
        </div>
    }

    <div class="table-glass-wrap">
        <table class="table-glass">
            <thead>
                <tr>
                    <th>العميل</th>
                    <th>نوع الباقة</th>
                    <th>تاريخ البداية</th>
                    <th>تاريخ الانتهاء</th>
                    <th>الساعات المتبقية</th>
                    <th>الحالة</th>
                    <th>السعر</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center fw-bold py-4">لا توجد باقات مسجلة حالياً.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-sapphire">@Html.DisplayFor(modelItem => item.Customer.Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.Package.Name)</td>
                        <td>@item.StartDate.ToString("yyyy/MM/dd")</td>
                        <td>@item.ExpiryDate.ToString("yyyy/MM/dd")</td>
                        <td class="fw-bold text-primary">@item.RemainingHours.ToString("0.##")</td>
                        <td>
                            <span class="badge-glass" style="background: @(item.Status == HubClub.Models.Enums.UserPackageStatus.Active ? "var(--azure-glow-soft)" : "rgba(239, 68, 68, 0.1)"); color: @(item.Status == HubClub.Models.Enums.UserPackageStatus.Active ? "var(--sapphire)" : "#ef4444"); border-color: @(item.Status == HubClub.Models.Enums.UserPackageStatus.Active ? "var(--azure-glow)" : "rgba(239, 68, 68, 0.2)");">
                                @Html.DisplayFor(modelItem => item.Status)
                            </span>
                        </td>
                        <td>@item.Price.ToString("N2") ج</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.UserPackageId" style="color: var(--azure); margin-left: 10px; font-weight: bold; text-decoration: none;">تعديل</a>
                            <a asp-action="Details" asp-route-id="@item.UserPackageId" style="color: var(--sapphire); margin-left: 10px; font-weight: bold; text-decoration: none;">تفاصيل</a>
                            <a asp-action="Delete" asp-route-id="@item.UserPackageId" style="color: #ef4444; font-weight: bold; text-decoration: none;">حذف</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>