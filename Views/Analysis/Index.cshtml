@model HubClub.ViewModels.AnalysisViewModel
@{
    ViewData["Title"] = "التحليل المالي";
}

<div class="container-fluid p-4" dir="rtl">
    <!-- العنوان -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: var(--sapphire); font-weight: 800; margin: 0;">التحليل المالي والمؤشرات</h2>
    </div>

    <!-- 1. الباقة الأكثر شعبية (كارت ملخص في الأعلى) -->
    <div class="analysis-summary-grid mb-5">
        <div class="summary-box">
            <div class="sb-title">الباقة الأكثر شعبية</div>
            <div class="sb-val" style="font-size: 2rem;">@Model.MostPopularPackageName</div>
            <div class="text-muted fw-bold">عدد المشتركين: @Model.MostPopularPackageCount</div>
        </div>
    </div>

    <div class="row g-4">
        <!-- 2. جدول أكثر المنتجات طلباً -->
        <div class="col-md-6">
            <h3 style="color: var(--sapphire); font-weight: 800; margin-bottom: 1rem;">أعلى 3 منتجات مبيعاً</h3>
            <div class="table-glass-wrap">
                <table class="table-glass">
                    <thead>
                        <tr>
                            <th>المنتج</th>
                            <th class="text-center">الكمية المباعة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.TopProducts)
                        {
                            <tr>
                                <td class="fw-bold">@item.Name</td>
                                <!-- تم استخدام ToString("F0") لإخفاء الكسور والأصفار -->
                                <td class="text-center">@item.Value.ToString("F0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 3. جدول أفضل 3 عملاء -->
        <div class="col-md-6">
            <h3 style="color: var(--sapphire); font-weight: 800; margin-bottom: 1rem;">أفضل 3 عملاء (إيرادات)</h3>
            <div class="table-glass-wrap">
                <table class="table-glass">
                    <thead>
                        <tr>
                            <th>العميل</th>
                            <th class="text-center">إجمالي الإيرادات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.TopCustomers)
                        {
                            <tr>
                                <td class="fw-bold">@item.Name</td>
                                <td class="text-center text-success fw-bold">@item.Value.ToString("N2") ج</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>