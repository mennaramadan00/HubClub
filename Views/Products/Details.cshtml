@model HubClub.Models.Product
@{
    ViewData["Title"] = "تفاصيل المنتج";
}

<link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />

<div class="detail-page">
    <div class="detail-card">
        <div class="detail-hero">
            <div class="product-icon">🛒</div>
            <h2>@Model.Name</h2>
            <div class="price-display">
                @Model.Price.ToString("N2") <span>جنيه</span>
            </div>
            <div>
                <span class="status-pill @(Model.IsActive ? "active" : "inactive")">
                    @(Model.IsActive ? "✓ متاح للبيع" : "✗ غير متاح")
                </span>
            </div>
        </div>

        <div class="detail-body">
            <div class="info-row">
                <span class="info-key">📦 الكمية المتاحة</span>
                <span class="info-val">
                    <span class="qty-badge @(Model.Quantity < 5 ? "low" : "ok")">
                        @Model.Quantity قطعة
                        @if (Model.Quantity < 5)
                        {
                            <text>⚠️</text>
                        }
                    </span>
                </span>
            </div>
            <div class="info-row">
                <span class="info-key">📅 تاريخ الإضافة</span>
                <span class="info-val">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="info-row">
                <span class="info-key">🕐 وقت الإضافة</span>
                <span class="info-val">@Model.CreatedAt.ToString("hh:mm tt")</span>
            </div>
        </div>

        <div class="detail-actions">
            <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn-edit">✏️ تعديل</a>
            <a asp-action="Delete" asp-route-id="@Model.ProductId" class="btn-delete">🗑 حذف</a>
        </div>
        <div style="text-align: center; margin-bottom: 1rem;">
            <a asp-action="Index" class="btn-back" style="border: none; background: transparent;">← العودة للقائمة</a>
        </div>
    </div>
</div>