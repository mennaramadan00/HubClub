@model HubClub.Models.Product
@{
    ViewData["Title"] = "تفاصيل المنتج";
}

<div class="glass-form-container" dir="rtl" style="max-width: 500px;">
    <div class="form-header text-center pb-4">
        <h2 style="font-size: 2rem; color: var(--sapphire);">@Model.Name</h2>
        <div class="mt-3 mb-2" style="font-size: 2rem; font-weight: 800; color: var(--sapphire);">
            @Model.Price.ToString("N2") <span style="font-size: 1.2rem;">ج.م</span>
        </div>
        <span class="badge-glass mt-2" style="font-size: 1rem; padding: 0.5rem 1rem;">
            @(Model.IsActive ? "متاح للبيع" : "غير متاح حالياً")
        </span>
    </div>

    <div class="mt-4">
        <div class="wf-data-row">
            <span class="wf-data-label">الكمية المتاحة (المخزون)</span>
            <span class="wf-data-val" style="color: @(Model.Quantity < 5 ? "#ef4444" : "var(--sapphire)");">
                @Model.Quantity قطعة
            </span>
        </div>
        <div class="wf-data-row">
            <span class="wf-data-label">تاريخ الإضافة</span>
            <span class="wf-data-val">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
        </div>
        <div class="wf-data-row">
            <span class="wf-data-label">وقت الإضافة</span>
            <span class="wf-data-val" dir="ltr">@Model.CreatedAt.ToString("hh:mm tt")</span>
        </div>
    </div>

    <div class="form-actions mt-5">
        <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn-aurelian-primary">تعديل البيانات</a>
        <a asp-action="Delete" asp-route-id="@Model.ProductId" class="btn-aurelian-outline" style="color: #ef4444; border-color: #ef4444;">حذف المنتج</a>
    </div>

    <div class="text-center mt-4">
        <a asp-action="Index" style="color: var(--sapphire); font-weight: 700; text-decoration: none;">العودة للقائمة</a>
    </div>
</div>