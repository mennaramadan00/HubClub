@model HubClub.Models.Product
@{
    ViewData["Title"] = "إضافة منتج";
}

<link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />

<div class="form-page">
    <div class="form-card">
        <div class="form-card-header">
            <h2>➕ إضافة منتج جديد</h2>
            <p>أضف منتجاً جديداً إلى قائمة البار</p>
        </div>
        <div class="form-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

                <div class="field-group">
                    <label class="field-label" asp-for="Name">
                        اسم المنتج <span class="required">*</span>
                    </label>
                    <input asp-for="Name" class="field-input" placeholder="مثال: قهوة، بيبسي، عصير..." />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label class="field-label" asp-for="Price">
                        السعر (جنيه) <span class="required">*</span>
                    </label>
                    <input asp-for="Price" class="field-input" type="number" step="0.01" min="0" placeholder="0.00" />
                    <span asp-validation-for="Price" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label class="field-label" asp-for="Quantity">
                        الكمية المتاحة <span class="required">*</span>
                    </label>
                    <input asp-for="Quantity" class="field-input" type="number" min="0" placeholder="0" />
                    <span asp-validation-for="Quantity" class="field-error"></span>
                </div>

                <div class="field-group">
                    <div class="toggle-group">
                        <input asp-for="IsActive" type="checkbox" id="IsActive" checked />
                        <label for="IsActive">المنتج متاح للبيع</label>
                    </div>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="btn-back">← رجوع</a>
                    <button type="submit" class="btn-save">💾 حفظ المنتج</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}