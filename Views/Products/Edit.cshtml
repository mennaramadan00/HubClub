@model HubClub.Models.Product
@{
    ViewData["Title"] = "تعديل المنتج";
}

<link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />

<div class="form-page">
    <div class="form-card">
        <div class="form-card-header">
            <div class="icon">✏️</div>
            <div>
                <h2>تعديل المنتج</h2>
                <p>@Model.Name</p>
            </div>
        </div>
        <div class="form-body">

            <div class="edit-notice">
                ⚠️ تعديل السعر لن يؤثر على الجلسات المسجّلة مسبقاً
            </div>

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>
                <input type="hidden" asp-for="ProductId" />

                <div class="field-group">
                    <label class="field-label" asp-for="Name">
                        اسم المنتج <span class="required">*</span>
                    </label>
                    <input asp-for="Name" class="field-input" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label class="field-label" asp-for="Price">
                        السعر (جنيه) <span class="required">*</span>
                    </label>
                    <input asp-for="Price" class="field-input" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Price" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label class="field-label" asp-for="Quantity">
                        الكمية المتاحة <span class="required">*</span>
                    </label>
                    <input asp-for="Quantity" class="field-input" type="number" min="0" />
                    <span asp-validation-for="Quantity" class="field-error"></span>
                </div>

                <div class="field-group">
                    <div class="toggle-group">
                        <input asp-for="IsActive" type="checkbox" id="IsActive" />
                        <label for="IsActive">المنتج متاح للبيع</label>
                    </div>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="btn-back">← رجوع</a>
                    <button type="submit" class="btn-save">💾 حفظ التعديلات</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}