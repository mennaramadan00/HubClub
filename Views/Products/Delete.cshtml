@model HubClub.Models.Product
@{
    ViewData["Title"] = "حذف المنتج";
}

<div class="glass-form-container" dir="rtl" style="max-width: 600px;">
    <div class="form-header text-center">
        <h2 style="color: #ef4444;">تأكيد الحذف</h2>
        <p>هذا الإجراء نهائي ولا يمكن التراجع عنه</p>
    </div>

    <div class="wf-card mx-auto mt-4" style="width: 100%; max-width: 100%;">
        <div class="wf-card-header text-center pb-3 mb-3">
            <h4 style="color: var(--sapphire); font-weight: 800; margin: 0;">@Model.Name</h4>
        </div>
        <div class="wf-data-row">
            <span class="wf-data-label">سعر البيع:</span>
            <span class="wf-data-val">@Model.Price.ToString("N2") ج.م</span>
        </div>
        <div class="wf-data-row mb-0">
            <span class="wf-data-label">الكمية المتبقية:</span>
            <span class="wf-data-val">@Model.Quantity قطعة</span>
        </div>
    </div>

    <div class="alert-glass mt-4" style="border-right-color: #ef4444;">
        <strong>تنبيه: هل أنت متأكد من حذف هذا المنتج؟</strong> <br />
        سيتم إزالته تماماً من قائمة البار ولن تتمكن من إضافته إلى الجلسات الجديدة.
    </div>

    <div class="form-actions mt-4">
        <form asp-action="Delete" method="post" style="flex: 1; display: flex; gap: 1rem; width: 100%;">
            <input type="hidden" asp-for="ProductId" />
            <button type="submit" class="btn-aurelian-primary" style="flex: 1; background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);">
                نعم، تأكيد الحذف
            </button>
            <a asp-action="Index" class="btn-aurelian-outline" style="flex: 1;">إلغاء الأمر</a>
        </form>
    </div>
</div>