@model HubClub.Models.PricingSetting
@{
    ViewData["Title"] = "إضافة شريحة تسعير";
}

<div class="glass-form-container" dir="rtl">
    <div class="form-header">
        <h2>إضافة شريحة جديدة</h2>
        <p>تحديد تسعير مخصص لعدد معين من الساعات</p>
    </div>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

        <div class="row">
            <div class="col-md-6">
                <label class="premium-label" asp-for="MinNumberOfHours">من (ساعة) <span class="text-danger">*</span></label>
                <input asp-for="MinNumberOfHours" class="premium-input" type="number" step="0.5" min="0" placeholder="الحد الأدنى..." />
                <span asp-validation-for="MinNumberOfHours" class="text-danger small mt-1 d-block fw-bold mb-3"></span>
            </div>
            <div class="col-md-6">
                <label class="premium-label" asp-for="MaxNumberOfHours">إلى (ساعة) <span class="text-danger">*</span></label>
                <input asp-for="MaxNumberOfHours" class="premium-input" type="number" step="0.5" min="0.5" placeholder="الحد الأقصى..." />
                <span asp-validation-for="MaxNumberOfHours" class="text-danger small mt-1 d-block fw-bold mb-3"></span>
            </div>
        </div>

        <div>
            <label class="premium-label" asp-for="Price">سعر الشريحة (ج.م) <span class="text-danger">*</span></label>
            <input asp-for="Price" class="premium-input" type="number" step="0.01" min="1" placeholder="مثال: 20" />
            <span asp-validation-for="Price" class="text-danger small mt-1 d-block fw-bold mb-4"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-aurelian-primary">حفظ الشريحة</button>
            <a asp-action="Index" class="btn-aurelian-outline">العودة للقائمة</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}