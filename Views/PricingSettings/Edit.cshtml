@model HubClub.Models.PricingSetting
@{
    ViewData["Title"] = "تعديل شريحة التسعير";
}

<div class="glass-form-container" dir="rtl">
    <div class="form-header">
        <h2>تعديل الشريحة</h2>
        <p>من @Model.MinNumberOfHours إلى @Model.MaxNumberOfHours ساعة</p>
    </div>

    <div class="alert-glass mb-4" style="border-right-color: var(--sapphire);">
        <strong>ملاحظة هامة:</strong> تعديل هذه الشريحة سيطبق على الجلسات الجديدة فقط، ولن يؤثر بأي شكل على الجلسات التي تم إغلاقها ومحاسبتها مسبقاً.
    </div>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>
        <input type="hidden" asp-for="PricingSettingId" />

        <div class="row">
            <div class="col-md-6">
                <label class="premium-label" asp-for="MinNumberOfHours">من (ساعة) <span class="text-danger">*</span></label>
                <!-- تم التعديل إلى step="any" -->
                <input asp-for="MinNumberOfHours" class="premium-input" type="number" step="any" min="0" />
                <span asp-validation-for="MinNumberOfHours" class="text-danger small mt-1 d-block fw-bold mb-3"></span>
            </div>
            <div class="col-md-6">
                <label class="premium-label" asp-for="MaxNumberOfHours">إلى (ساعة) <span class="text-danger">*</span></label>
                <!-- تم التعديل إلى step="any" -->
                <input asp-for="MaxNumberOfHours" class="premium-input" type="number" step="any" min="0" />
                <span asp-validation-for="MaxNumberOfHours" class="text-danger small mt-1 d-block fw-bold mb-3"></span>
            </div>
        </div>

        <div>
            <label class="premium-label" asp-for="Price">سعر الشريحة (ج.م) <span class="text-danger">*</span></label>
            <!-- تم التعديل إلى step="any" -->
            <input asp-for="Price" class="premium-input" type="number" step="any" min="1" />
            <span asp-validation-for="Price" class="text-danger small mt-1 d-block fw-bold mb-4"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-aurelian-primary">حفظ التعديلات</button>
            <a asp-action="Index" class="btn-aurelian-outline">العودة للقائمة</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}