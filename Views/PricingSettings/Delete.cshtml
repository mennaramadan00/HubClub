@model HubClub.Models.PricingSetting
@{
    ViewData["Title"] = "حذف الشريحة";
}

<link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />

<div class="delete-page">
    <div class="delete-card">
        <div class="delete-header">
            <div class="delete-icon">🗑️</div>
            <h2>تأكيد الحذف</h2>
            <p>هذا الإجراء لا يمكن التراجع عنه</p>
        </div>

        <div class="delete-body">
            <div class="product-preview">
                <div class="pname">الشريحة الحالية</div>
                <div class="pdetails" style="flex-direction: column; align-items: center; gap: 0.5rem;">
                    <span>المدة: <strong>من @Model.MinNumberOfHours إلى @Model.MaxNumberOfHours ساعة</strong></span>
                    <span>السعر: <strong>@Model.Price.ToString("N2") جنيه</strong></span>
                </div>
            </div>

            <div class="warning-box">
                ⚠️ هل أنت متأكد من حذف هذه الشريحة؟ <br />
                لن يؤثر الحذف على الجلسات السابقة، ولكن الجلسات الجديدة لن تتمكن من استخدام هذا السعر.
            </div>
        </div>

        <div class="delete-actions">
            <a asp-action="Index" class="btn-cancel">← إلغاء</a>
            <form asp-action="Delete" method="post" style="flex:1;">
                <input type="hidden" asp-for="PricingSettingId" />
                <button type="submit" class="btn-confirm-delete" style="width:100%;">
                    🗑 نعم، احذف الشريحة
                </button>
            </form>
        </div>
    </div>
</div>