@model HubClub.Models.ExpenseCategory

@{
    ViewData["Title"] = "حذف البند";
}

<div class="glass-form-container">
    <div class="form-header">
        <h2 style="color: #dc3545;">تأكيد الحذف</h2>
        <p>هل أنت متأكد من رغبتك في حذف هذا البند؟ لا يمكن التراجع عن هذه الخطوة.</p>
    </div>

    <div class="wf-card" style="min-width: 100%; box-shadow: none; border-color: rgba(220,53,69,0.2);">
        <div class="wf-data-row">
            <span class="wf-data-label">اسم البند</span>
            <span class="wf-data-val">@Html.DisplayFor(model => model.Name)</span>
        </div>
        <div class="wf-data-row">
            <span class="wf-data-label">الوصف</span>
            <span class="wf-data-val">@Html.DisplayFor(model => model.Description)</span>
        </div>
    </div>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="ExpenseCategoryId" />
        <div class="form-actions">
            <!-- استخدمنا ستايل خاص لزرار الحذف ليتماشى مع التصميم الزجاجي -->
            <button type="submit" class="btn-aurelian-primary" style="background: linear-gradient(135deg, #ff4d4d 0%, #cc0000 100%);">
                <i class="fas fa-trash-alt me-2"></i> نعم، احذف البند
            </button>
            <a asp-action="Index" class="btn-aurelian-outline">إلغاء والعودة</a>
        </div>
    </form>
</div>