@model IEnumerable<HubClub.Models.ExpenseCategory>

@{
    ViewData["Title"] = "بنود المصروفات";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h1 class="topbar-title">إدارة بنود المصروفات</h1>
    <a asp-action="Create" class="btn-aurelian-primary">
        <i class="fas fa-plus me-2"></i> إضافة بند جديد
    </a>
</div>

<div class="table-glass-wrap">
    <table class="table-glass">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>الوصف والملاحظات</th>
                <th style="text-align: center;">الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-weight: 800; color: var(--sapphire); font-size: 1.1rem;">
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td style="color: var(--text-slate);">
                        @Html.DisplayFor(modelItem => item.Description)
                    </td>
                    <td style="text-align: center;">
                        <a asp-action="Details" asp-route-id="@item.ExpenseCategoryId" class="badge-glass text-decoration-none mx-1">
                            <i class="fas fa-eye me-1"></i> التفاصيل
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.ExpenseCategoryId" class="badge-glass text-decoration-none mx-1" style="background: var(--nav-yellow-soft); border-color: var(--nav-yellow-border); color: #C9631A;">
                            <i class="fas fa-edit me-1"></i> تعديل
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.ExpenseCategoryId" class="badge-glass text-decoration-none mx-1" style="background: rgba(220,53,69,0.05); border-color: rgba(220,53,69,0.2); color: #dc3545;">
                            <i class="fas fa-trash me-1"></i> حذف
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>