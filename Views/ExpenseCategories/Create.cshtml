@model HubClub.Models.ExpenseCategory

@{
    ViewData["Title"] = "إضافة بند مصروفات";
}

<div class="glass-form-container">
    <div class="form-header">
        <h2>إضافة بند مصروفات جديد</h2>
        <p>قم بتسجيل نوع جديد للمصروفات (مثل: فواتير، رواتب، بضاعة...)</p>
    </div>

    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="Name" class="premium-label"></label>
            <input asp-for="Name" class="premium-input" placeholder="مثال: فواتير كهرباء..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="premium-label"></label>
            <input asp-for="Description" class="premium-input" placeholder="ملاحظات توضيحية (اختياري)..." />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-aurelian-primary">
                <i class="fas fa-save me-2"></i> حفظ البند
            </button>
            <a asp-action="Index" class="btn-aurelian-outline">العودة للقائمة</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}