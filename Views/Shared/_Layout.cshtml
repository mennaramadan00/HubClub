@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    Func<string, string, string> navActive = (ctrl, act) =>
        (currentController == ctrl && (act == null || currentAction == act)) ? "active" : "";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HubClub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/hubclub.css" asp-append-version="true" />
</head>
<body>
    <div class="app-wrapper">
        <!-- Sidebar Menu -->
        <aside class="app-sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                    <span>Hub Club</span>
                </a>
            </div>
            <nav class="sidebar-nav">
                <!-- تم إرجاع أسماء الـ Controllers الأصلية (بصيغة الجمع) هنا حتى تعمل الروابط -->
                <a class="nav-item-link @navActive("Home", "Index")" asp-controller="Home" asp-action="Index">إدارة الجلسات</a>
                <a class="nav-item-link @navActive("Home", "DailyAnalysis")" asp-controller="Home" asp-action="DailyAnalysis">التحليل المالي اليومي</a>
                <a class="nav-item-link @navActive("Products", null)" asp-controller="Products" asp-action="Index">المنتجات والبار</a>
                <a class="nav-item-link @navActive("PricingSettings", null)" asp-controller="PricingSettings" asp-action="Index">إعدادات التسعير</a>
                <a class="nav-item-link @navActive("Packages", null)" asp-controller="Packages" asp-action="Index">إدارة الباقات</a>
                <a class="nav-item-link @navActive("UserPackage", null)" asp-controller="UserPackage" asp-action="Index">باقات المشتركين</a>
                <a class="nav-item-link @navActive("Customers", null)" asp-controller="Customers" asp-action="Index">قاعدة العملاء</a>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="app-main">
            <!-- Top Nav Bar -->
            @* <header class="app-topbar">
                <h1 class="topbar-title">@ViewData["Title"]</h1>
                <a asp-controller="Session" asp-action="Open" class="btn-aurelian-primary">
                    بدء جلسة جديدة
                </a>
            </header> *@

            <div class="p-4">
                <!-- تم إزالة رسائل النجاح تماماً -->
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>