@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    Func<string, string> navActive = ctrl => currentController == ctrl ? "active" : "";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HubClub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HubClub.styles.css" asp-append-version="true" />
    <!-- ملفات الستايل الموحدة: التصميم الجديد بألوان المحيط -->
    <link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm fancy-navbar mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Hub<span>Club</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @navActive("Home")" asp-area="" asp-controller="Home" asp-action="Index"> الرئيسية</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @navActive("Customers")" asp-area="" asp-controller="Customers" asp-action="Index"> العملاء</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @navActive("Packages")" asp-area="" asp-controller="Packages" asp-action="Index"> الباقات</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @navActive("Products")" asp-area="" asp-controller="Products" asp-action="Index"> البار والمنتجات</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @navActive("PricingSettings")" asp-area="" asp-controller="PricingSettings" asp-action="Index"> التسعير</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @navActive("UserPackage")" asp-area="" asp-controller="UserPackage" asp-action="Index">
                                 باقات العملاء
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid main-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* <footer class="fancy-footer">
        <div class="container-fluid px-4">
            &copy; @DateTime.Now.Year <a asp-area="" asp-controller="Home" asp-action="Index">HubClub</a> — كل الحقوق محفوظة
        </div>
    </footer> *@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
