@model HubClub.ViewModels.SessionCloseViewModel
@{
    ViewData["Title"] = "إنهاء وإغلاق الجلسة";
}

<form asp-action="ConfirmClose" method="post" id="closeForm" dir="rtl">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="SessionId" />
    <input type="hidden" asp-for="PaymentType" />
    <input type="hidden" asp-for="StartTime" />
    <input type="hidden" asp-for="EndTime" />
    <input type="hidden" asp-for="HoursElapsed" />
    <input type="hidden" asp-for="CalculatedTimePrice" />

    <div class="row">
        <!-- قسم إضافة منتجات جديدة -->
        <div class="col-md-8 mb-4">
            <h4 style="font-weight: 800; color: var(--sapphire); margin-bottom: 1.5rem;">إضافة طلبات جديدة (اختياري)</h4>

            <div class="product-squares-grid">
                @for (int i = 0; i < Model.AvailableProducts.Count; i++)
                {
                    var p = Model.AvailableProducts[i];
                    <div class="product-square" id="pcard-@i" style="@(p.AvailableStock <= 0 ? "opacity: 0.5; pointer-events: none;" : "")">
                        <input type="hidden" name="AvailableProducts[@i].ProductId" value="@p.ProductId" />
                        <input type="hidden" name="AvailableProducts[@i].Name" value="@p.Name" />
                        <input type="hidden" name="AvailableProducts[@i].Price" value="@p.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" />

                        <div class="ps-info">
                            <div class="ps-name">@p.Name</div>
                            <div style="font-size: 0.85rem; color: var(--text-slate); font-weight: 600;">@p.Price.ToString("N2") ج.م</div>
                        </div>

                        <div class="ps-action-bar">
                            <button type="button" class="ps-btn" onclick="changeQty(@i, -1, @p.AvailableStock)">-</button>
                            <input type="number" id="qty-@i" class="ps-qty" name="AvailableProducts[@i].SelectedQuantity" value="0" readonly />
                            <button type="button" class="ps-btn" onclick="changeQty(@i, 1, @p.AvailableStock)">+</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ملخص الجلسة وتعديل الطلبات القديمة -->
        <div class="col-md-4">
            <div class="wf-card" style="width: 100%; max-width: 100%;">
                <h4 style="font-weight: 800; color: var(--sapphire); margin-bottom: 1rem; border-bottom: 2px solid var(--glass-edge-blue); padding-bottom: 0.8rem;">فاتورة الجلسة</h4>

                <div class="wf-data-row"><span class="wf-data-label">العميل</span> <span class="wf-data-val">@Model.CustomerName</span></div>
                <div class="wf-data-row"><span class="wf-data-label">مدة الجلسة</span> <span class="wf-data-val">@Model.HoursElapsed.ToString("0.##") ساعة</span></div>

                <!-- قائمة الطلبات القديمة (أصبحت قابلة للتعديل الآن) -->
                @if (Model.AlreadyAddedProducts.Any())
                {
                    <div class="mt-3 mb-2 px-2" style="font-size: 0.9rem; color: var(--sapphire); font-weight: 800;">الطلبات المسجلة مسبقاً (يمكنك تعديلها):</div>
                    <div style="background: rgba(255, 255, 255, 0.6); padding: 0.5rem; border-radius: 4px; border: 1px solid var(--glass-edge-blue); margin-bottom: 1rem;">

                        @for (int j = 0; j < Model.AlreadyAddedProducts.Count; j++)
                        {
                            var oldItem = Model.AlreadyAddedProducts[j];
                            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom" style="border-color: rgba(22, 41, 107, 0.05) !important;">
                                <!-- حقل مخفي لإرسال الـ ID للـ Backend -->
                                <input type="hidden" name="AlreadyAddedProducts[@j].ProductId" value="@oldItem.ProductId" />

                                <div class="d-flex flex-column">
                                    <span style="font-size: 0.9rem; font-weight: 800; color: var(--sapphire);">@oldItem.ProductName</span>
                                    <strong style="color: var(--text-slate); font-size: 0.8rem;" id="old-line-total-@j">@oldItem.LineTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ج.م</strong>
                                </div>

                                <!-- زراير التحكم في الكمية للمنتجات القديمة -->
                                <div class="ps-action-bar" style="background: transparent; border: 1px solid var(--glass-edge-blue); border-radius: 6px;">
                                    <button type="button" class="ps-btn" style="padding: 0.1rem 0.5rem; font-size: 1rem;" onclick="changeOldQty(@j, -1)">-</button>
                                    <input type="number" id="old-qty-@j" name="AlreadyAddedProducts[@j].Quantity" value="@oldItem.Quantity" readonly style="width: 30px; text-align: center; border: none; background: transparent; font-weight: bold; color: var(--sapphire);" />
                                    <button type="button" class="ps-btn" style="padding: 0.1rem 0.5rem; font-size: 1rem;" onclick="changeOldQty(@j, 1)">+</button>
                                </div>
                            </div>
                        }

                    </div>
                }

                <div class="wf-data-row mt-3">
                    <span class="wf-data-label">تكلفة الوقت</span>
                    <span class="wf-data-val" id="timeTotal">@(Model.IsPackageSession ? "0.00 (باقة)" : Model.CalculatedTimePrice.ToString("N2"))</span>
                </div>

                <div class="wf-data-row">
                    <span class="wf-data-label">إجمالي البار</span>
                    <span class="wf-data-val" id="productsTotal">@Model.TotalProductPrice.ToString("N2")</span>
                </div>

                <div class="wf-data-row mt-4" style="background: var(--sapphire); border-color: var(--sapphire);">
                    <span class="wf-data-label" style="color: rgba(255,255,255,0.85);">الإجمالي النهائي المطلوب</span>
                    <span class="wf-data-val" id="grandTotal" style="font-size: 1.3rem; color: #ffffff;">
                        @((Model.IsPackageSession ? Model.TotalProductPrice : Model.CalculatedTimePrice + Model.TotalProductPrice).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))
                    </span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-aurelian-primary flex-grow-1" onclick="return confirm('هل أنت متأكد من إغلاق الجلسة بشكل نهائي؟')">
                        تأكيد وإغلاق الجلسة
                    </button>
                    <a asp-controller="Home" asp-action="Index" class="btn-aurelian-outline flex-grow-1">إلغاء</a>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
    // أسعار المنتجات الجديدة
    const prices = {
        @for (int i = 0; i < Model.AvailableProducts.Count; i++)
        {
                    @:@i: @Model.AvailableProducts[i].Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture),
        }
    };

    // أسعار المنتجات القديمة
    const oldPrices = {
        @for (int j = 0; j < Model.AlreadyAddedProducts.Count; j++)
        {
                var price = Model.AlreadyAddedProducts[j].Quantity > 0 ? (Model.AlreadyAddedProducts[j].LineTotal / Model.AlreadyAddedProducts[j].Quantity) : 0;
                @:@j: @price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture),
        }
    };

    const timeCost = @(Model.IsPackageSession ? "0" : Model.CalculatedTimePrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));

    // تعديل كمية المنتجات الجديدة
    function changeQty(index, delta, maxStock) {
        const input = document.getElementById('qty-' + index);
        const current = parseInt(input.value) || 0;
        const newVal = Math.max(0, Math.min(current + delta, maxStock));
        input.value = newVal;
        recalc();
    }

    // تعديل كمية المنتجات القديمة
    function changeOldQty(index, delta) {
        const input = document.getElementById('old-qty-' + index);
        const current = parseInt(input.value) || 0;
        const newVal = Math.max(0, current + delta); // يسمح بالنزول حتى صفر (لإلغاء المنتج)
        input.value = newVal;

        const lineTotal = newVal * oldPrices[index];
        document.getElementById('old-line-total-' + index).textContent = lineTotal.toFixed(2) + " ج.م";

        recalc();
    }

    // إعادة الحساب الشاملة
    function recalc() {
        let newProductTotal = 0;
        Object.keys(prices).forEach(i => {
            const qty = parseInt(document.getElementById('qty-' + i)?.value) || 0;
            newProductTotal += qty * prices[i];
        });

        let oldProductTotal = 0;
        Object.keys(oldPrices).forEach(j => {
            const qty = parseInt(document.getElementById('old-qty-' + j)?.value) || 0;
            oldProductTotal += qty * oldPrices[j];
        });

        const finalProductTotal = oldProductTotal + newProductTotal;
        const grand = timeCost + finalProductTotal;

        document.getElementById('productsTotal').textContent = finalProductTotal.toFixed(2);
        document.getElementById('grandTotal').textContent    = grand.toFixed(2);
    }
</script>