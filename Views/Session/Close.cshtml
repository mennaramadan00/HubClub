@model HubClub.ViewModels.SessionCloseViewModel
@using HubClub.Models.Enums
@{
    ViewData["Title"] = "إغلاق الجلسة";
}

<link rel="stylesheet" href="~/css/product.css" />

<style>
    .close-hero {
        background: linear-gradient(135deg, var(--blue-900), var(--blue-700));
        border-radius: 1rem;
        padding: 1.5rem 2rem;
        color: var(--white);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .close-hero h2 { margin: 0; font-size: 1.4rem; font-weight: 800; }
    .close-hero p  { margin: 0.2rem 0 0; color: var(--blue-100); font-size: 0.85rem; }

    /* Time summary card */
    .time-card {
        background: var(--white);
        border: 1px solid var(--blue-100);
        border-radius: 0.85rem;
        padding: 1.2rem 1.5rem;
        margin-bottom: 1.2rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .time-card .tc-head {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--blue-700);
        margin-bottom: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .time-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 0.9rem;
    }
    .time-tile { text-align: center; }
    .time-tile .tt-label { font-size: 0.72rem; color: var(--gray-400); margin-bottom: 0.2rem; }
    .time-tile .tt-val   { font-size: 1.1rem; font-weight: 800; color: var(--blue-900); }

    .pricing-badge {
        background: var(--blue-50);
        border: 1px solid var(--blue-100);
        border-radius: 0.5rem;
        padding: 0.6rem 1rem;
        font-size: 0.82rem;
        color: var(--blue-800);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .pricing-badge .pb-price {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--yellow);
    }

    .package-badge {
        background: var(--yellow-light);
        border: 1px solid #fcd34d;
        border-radius: 0.5rem;
        padding: 0.6rem 1rem;
        font-size: 0.83rem;
        color: #92400e;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Products section */
    .section-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--blue-900);
        margin: 1.4rem 0 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .products-select-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 0.8rem;
        margin-bottom: 1.5rem;
    }

    .psc-card {
        background: var(--white);
        border: 2px solid var(--blue-100);
        border-radius: 0.75rem;
        padding: 0.9rem;
        text-align: center;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .psc-card.selected {
        border-color: var(--blue-600);
        box-shadow: 0 0 0 3px rgba(37,99,168,0.1);
        background: var(--blue-50);
    }
    .psc-card.out-of-stock {
        opacity: 0.45;
        pointer-events: none;
    }
    .psc-name  { font-weight: 700; color: var(--blue-900); font-size: 0.88rem; margin-bottom: 0.2rem; }
    .psc-price { color: var(--yellow); font-weight: 800; font-size: 0.95rem; margin-bottom: 0.6rem; }
    .psc-stock { font-size: 0.7rem; color: var(--gray-400); margin-bottom: 0.6rem; }

    .qty-control {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
    }
    .qty-btn {
        width: 28px; height: 28px; border-radius: 50%;
        border: none;
        font-size: 1rem; font-weight: 700; line-height: 1;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.15s;
    }
    .qty-btn.plus  { background: var(--blue-600); color: white; }
    .qty-btn.plus:hover  { background: var(--blue-800); }
    .qty-btn.minus { background: var(--gray-300); color: var(--gray-600); }
    .qty-btn.minus:hover { background: var(--gray-400); }
    .qty-display {
        width: 34px; height: 28px;
        text-align: center;
        border: 1.5px solid var(--gray-300);
        border-radius: 0.4rem;
        font-size: 0.88rem; font-weight: 700;
        color: var(--blue-900);
    }

    /* Totals box */
    .totals-box {
        background: var(--blue-900);
        border-radius: 0.85rem;
        padding: 1.2rem 1.5rem;
        color: var(--white);
        margin-bottom: 1.5rem;
    }
    .total-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.88rem;
        color: var(--blue-100);
        padding: 0.35rem 0;
    }
    .total-row.grand {
        border-top: 1px solid rgba(255,255,255,0.15);
        margin-top: 0.5rem;
        padding-top: 0.8rem;
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--yellow);
    }

    .action-bar { display: flex; gap: 0.8rem; flex-wrap: wrap; }
    .btn-confirm {
        flex: 1; min-width: 160px;
        background: var(--danger);
        color: white;
        border: none;
        border-radius: 0.6rem;
        padding: 0.85rem 1.2rem;
        font-size: 1rem; font-weight: 700;
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s;
    }
    .btn-confirm:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(239,68,68,0.3);
    }
</style>

<div class="container-fluid px-4 py-4">

    <!-- Header -->
    <div class="close-hero">
        <div>
            <h2>🏁 إغلاق جلسة — @Model.CustomerName</h2>
            <p>مراجعة الحساب قبل تأكيد الإغلاق</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn-back"
           style="color:white; border-color:rgba(255,255,255,0.3);">
            ← رجوع
        </a>
    </div>

    <form asp-action="ConfirmClose" method="post" id="closeForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SessionId" />
        <input type="hidden" asp-for="PaymentType" />
        <input type="hidden" asp-for="StartTime" />
        <input type="hidden" asp-for="EndTime" />
        <input type="hidden" asp-for="HoursElapsed" />
        <input type="hidden" asp-for="CalculatedTimePrice" />

        <!-- Time summary -->
        <div class="time-card">
            <div class="tc-head">⏱ ملخص الوقت</div>
            <div class="time-grid">
                <div class="time-tile">
                    <div class="tt-label">وقت الدخول</div>
                    <div class="tt-val">@Model.StartTime.ToString("hh:mm tt")</div>
                </div>
                <div class="time-tile">
                    <div class="tt-label">وقت الخروج</div>
                    <div class="tt-val">@Model.EndTime.ToString("hh:mm tt")</div>
                </div>
                <div class="time-tile">
                    <div class="tt-label">المدة الكلية</div>
                    <div class="tt-val">@Model.HoursElapsed.ToString("0.##") ساعة</div>
                </div>
            </div>

            @if (Model.IsPackageSession)
            {
                <div class="package-badge">
                    📦 العميل مشترك بباقة — لا يوجد رسوم وقت — سيتم خصم الساعات من رصيده
                </div>
            }
            else
            {
                <div class="pricing-badge">
                    <span>
                        🏷️ شريحة التسعير المطبقة:
                        <strong>@(Model.PricingRangeLabel ?? "غير محدد")</strong>
                    </span>
                    <span class="pb-price">@Model.CalculatedTimePrice.ToString("N2") ج</span>
                </div>
            }
        </div>

        <!-- Products selection -->
        <div class="section-title">🛒 ما أخده العميل من البار</div>
        <p style="font-size: 0.82rem; color: var(--gray-400); margin-bottom: 1rem;">
            حدد المنتجات التي طلبها العميل خلال الجلسة — الكميات ستُخصم من المخزون تلقائياً
        </p>

        @if (!Model.AvailableProducts.Any())
        {
            <div class="empty-state" style="padding: 1.5rem;">
                <p>لا توجد منتجات متاحة في المخزون</p>
            </div>
        }
        else
        {
            <div class="products-select-grid">
                @for (int i = 0; i < Model.AvailableProducts.Count; i++)
                {
                    var p = Model.AvailableProducts[i];
                    <div class="psc-card @(p.AvailableStock <= 0 ? "out-of-stock" : "")" id="pcard-@i">
                        <input type="hidden" name="AvailableProducts[@i].ProductId"    value="@p.ProductId" />
                        <input type="hidden" name="AvailableProducts[@i].Name"         value="@p.Name" />
                        <input type="hidden" name="AvailableProducts[@i].Price"        value="@p.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" />
                        <input type="hidden" name="AvailableProducts[@i].AvailableStock" value="@p.AvailableStock" />

                        <div class="psc-name">@p.Name</div>
                        <div class="psc-price">@p.Price.ToString("N2") ج</div>
                        <div class="psc-stock">
                            @(p.AvailableStock <= 0 ? "نفد المخزون" : $"متاح: {p.AvailableStock}")
                        </div>

                        <div class="qty-control">
                            <button type="button" class="qty-btn minus"
                                    onclick="changeQty(@i, -1, @p.AvailableStock)">−</button>
                            <input type="number"
                                   class="qty-display"
                                   id="qty-@i"
                                   name="AvailableProducts[@i].SelectedQuantity"
                                   value="0"
                                   min="0"
                                   max="@p.AvailableStock"
                                   readonly />
                            <button type="button" class="qty-btn plus"
                                    onclick="changeQty(@i, 1, @p.AvailableStock)">＋</button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Totals -->
        <div class="totals-box">
            <div class="total-row">
                <span>⏱ تكلفة الوقت</span>
                <span id="timeTotal">
                    @(Model.IsPackageSession
                        ? "مشمول في الباقة"
                        : Model.CalculatedTimePrice.ToString("N2") + " ج")
                </span>
            </div>
            <div class="total-row">
                <span>🛒 تكلفة المنتجات</span>
                <span id="productsTotal">0.00 ج</span>
            </div>
            <div class="total-row grand">
                <span>💰 الإجمالي المطلوب</span>
                <span id="grandTotal">
                    @(Model.IsPackageSession
                        ? "0.00"
                        : Model.CalculatedTimePrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))
                    ج
                </span>
            </div>
        </div>

        <!-- Actions -->
        <div class="action-bar">
            <a asp-controller="Home" asp-action="Index" class="btn-back">← إلغاء</a>
            <button type="submit" class="btn-confirm"
                    onclick="return confirm('تأكيد إغلاق الجلسة وحفظ الحساب؟')">
                ✅ تأكيد الإغلاق
            </button>
        </div>
    </form>
</div>

<script>
    const prices = {
        @for (int i = 0; i < Model.AvailableProducts.Count; i++)
        {
            @:@i: @Model.AvailableProducts[i].Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture),
        }
    };

    const timeCost = @(Model.IsPackageSession ? "0" : Model.CalculatedTimePrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));

    function changeQty(index, delta, maxStock) {
        const input = document.getElementById('qty-' + index);
        const current = parseInt(input.value) || 0;
        const newVal = Math.max(0, Math.min(current + delta, maxStock));
        input.value = newVal;

        const card = document.getElementById('pcard-' + index);
        card.classList.toggle('selected', newVal > 0);

        recalc();
    }

    function recalc() {
        let productTotal = 0;
        Object.keys(prices).forEach(i => {
            const qty = parseInt(document.getElementById('qty-' + i)?.value) || 0;
            productTotal += qty * prices[i];
        });

        const grand = timeCost + productTotal;

        document.getElementById('productsTotal').textContent = productTotal.toFixed(2) + ' ج';
        document.getElementById('grandTotal').textContent    = grand.toFixed(2) + ' ج';
    }
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
