@model HubClub.ViewModels.SessionOpenViewModel
@{
    ViewData["Title"] = "فتح جلسة جديدة";
}

<div class="glass-form-container" dir="rtl">
    <div class="form-header">
        <h2>بدء جلسة جديدة</h2>
        <p>الخطوة الأولى في تجربة العميل داخل النظام</p>
    </div>

    <form asp-action="Open" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

        <!-- وقت البداية -->
        <div>
            <label class="premium-label">وقت البداية</label>
            <input type="text" class="premium-input text-center fw-bold" style="opacity: 0.8; background: var(--bg-canvas);" value="@Model.StartTime.ToString("dd/MM/yyyy - hh:mm tt")" disabled />
        </div>

        <!-- هوية العميل -->
        <div style="margin-top: 1.5rem;">
            <label class="premium-label mb-3 text-center">هوية العميل</label>

            <!-- أزرار الاختيار (Radio Buttons) -->
            <div class="d-flex gap-5 mb-4 justify-content-center">
                <label class="d-flex align-items-center gap-2" style="cursor: pointer;">
                    <input type="radio" asp-for="IsNewCustomer" value="false" onchange="toggleCustomer(false)" style="transform: scale(1.3); accent-color: var(--sapphire);" />
                    <span class="fw-bold fs-5" style="color: var(--sapphire);">عميل مسجل</span>
                </label>
                <label class="d-flex align-items-center gap-2" style="cursor: pointer;">
                    <input type="radio" asp-for="IsNewCustomer" value="true" onchange="toggleCustomer(true)" style="transform: scale(1.3); accent-color: var(--sapphire);" />
                    <span class="fw-bold fs-5" style="color: var(--sapphire);">عميل جديد</span>
                </label>
            </div>

            <!-- العميل المسجل -->
            <div id="divExisting">
                <select asp-for="SelectedCustomerId" asp-items="Model.AllCustomers" id="SelectedCustomerId" class="premium-input select2-search">
                    <option value="">-- ابحث بالاسم أو الموبايل --</option>
                </select>
                <span asp-validation-for="SelectedCustomerId" class="text-danger small mt-1 d-block fw-bold"></span>
            </div>

            <!-- العميل الجديد -->
            <div id="divNew" style="display: none;">
                <input type="text" asp-for="NewCustomerName" id="NewCustomerName" class="premium-input" placeholder="اسم العميل (الاسم الأول والأخير) *" />
                <span asp-validation-for="NewCustomerName" class="text-danger small mt-1 d-block mb-1 fw-bold"></span>

                <input type="text" asp-for="NewCustomerPhone" id="NewCustomerPhone" class="premium-input" placeholder="رقم الهاتف *" />
                <span asp-validation-for="NewCustomerPhone" class="text-danger small mt-1 d-block fw-bold"></span>
            </div>
        </div>

        <!-- نظام الدفع -->
        <div style="margin-top: 1.5rem;">
            <label class="premium-label">نظام الدفع</label>
            <select asp-for="PaymentType" id="PaymentType" class="premium-input">
                <option value="0">الدفع النقدي (بالساعة)</option>
                <option value="1">خصم من رصيد الباقة</option>
            </select>
            <span asp-validation-for="PaymentType" class="text-danger small mt-1 d-block fw-bold"></span>
        </div>

        <!-- زراير الأكشن -->
        <div class="form-actions">
            <button type="submit" class="btn-aurelian-primary">تأكيد وبدء الجلسة</button>
            <a asp-controller="Home" asp-action="Index" class="btn-aurelian-outline">إلغاء الأمر</a>
        </div>
    </form>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <style>
        /* تنسيق مكتبة Select2 لتطابق تصميم Sapphire Glass */
        .select2-container--default .select2-selection--single {
            height: auto !important;
            padding: 0.8rem 1.2rem;
            border: 2px solid rgba(22, 41, 107, 0.1) !important;
            border-radius: var(--radius-sharp) !important;
            background: rgba(255, 255, 255, 0.85) !important;
            color: var(--text-ink) !important;
            font-family: var(--font-ar) !important;
            font-size: 1rem !important;
            transition: all 0.3s ease;
        }

            .select2-container--default .select2-selection--single:focus,
            .select2-container--default.select2-container--open .select2-selection--single {
                outline: none;
                border-color: var(--azure) !important;
                box-shadow: 0 0 0 4px var(--azure-glow-soft) !important;
                background: #ffffff !important;
            }

            .select2-container--default .select2-selection--single .select2-selection__arrow {
                top: 50% !important;
                transform: translateY(-50%);
                left: 15px !important;
                right: auto !important;
            }

            .select2-container--default .select2-selection--single .select2-selection__rendered {
                color: var(--text-ink) !important;
                line-height: normal !important;
                padding-right: 0 !important;
                padding-left: 20px !important;
                font-weight: 600;
            }

        .select2-dropdown {
            background: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(15px) !important;
            border: 1px solid var(--azure) !important;
            border-radius: var(--radius-sharp) !important;
            box-shadow: var(--shadow-float) !important;
        }

        .select2-results__option {
            font-family: var(--font-ar);
            color: var(--sapphire);
            padding: 0.8rem 1.2rem !important;
            font-weight: 600;
            border-bottom: 1px solid rgba(22, 41, 107, 0.05);
        }

        .select2-container--default .select2-results__option--highlighted[aria-selected] {
            background-color: var(--azure-glow-soft) !important;
            color: var(--sapphire) !important;
        }
    </style>

    <script>
        $(document).ready(function() {
            $('#SelectedCustomerId').select2({ dir: "rtl", width: '100%' });

            var isNew = $('input[name="IsNewCustomer"]:checked').val() === 'true';
            toggleCustomer(isNew);
        });

        function toggleCustomer(isNew) {
            if (isNew) {
                $('#divExisting').hide();
                $('#divNew').fadeIn(300);
                $('#SelectedCustomerId').prop('disabled', true);
                $('#NewCustomerName, #NewCustomerPhone').prop('disabled', false);

                // منع اختيار الباقة للعميل الجديد (QA Fix)
                $('#PaymentType').val('0');
                $('#PaymentType option[value="1"]').prop('disabled', true);

            } else {
                $('#divExisting').fadeIn(300);
                $('#divNew').hide();
                $('#SelectedCustomerId').prop('disabled', false);
                $('#NewCustomerName, #NewCustomerPhone').prop('disabled', true);

                // إعادة تفعيل اختيار الباقة للعميل المسجل
                $('#PaymentType option[value="1"]').prop('disabled', false);
            }
        }
    </script>
}