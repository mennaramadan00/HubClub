@model HubClub.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "التحليل المالي ليوم العمل";
}

<div class="analysis-summary-grid" style="margin-bottom: 3rem;">
    <div class="summary-box">
        <div class="sb-title">إيرادات البار ليوم العمل</div>
        <div class="sb-val">@Model.TodayTotalProductCash.ToString("N2") <span style="font-size: 1rem; font-weight: 600;">ج.م</span></div>
    </div>
    <div class="summary-box">
        <div class="sb-title">إيرادات الجلسات ليوم العمل</div>
        <div class="sb-val">@Model.TodayTotalTimeCash.ToString("N2") <span style="font-size: 1rem; font-weight: 600;">ج.م</span></div>
    </div>
    <div class="summary-box">
        <div class="sb-title">مبيعات الباقات ليوم العمل</div>
        <div class="sb-val" style="background: linear-gradient(120deg, var(--violet-hint) 0%, var(--nav-orange-text) 100%); -webkit-background-clip: text; color: transparent;">
            @Model.TodayTotalPackageCash.ToString("N2")
            <span style="font-size: 1rem; font-weight: 600; color: var(--text-slate); -webkit-text-fill-color: var(--text-slate);">ج.م</span>
        </div>
    </div>
    <div class="summary-box" style="background: linear-gradient(135deg, var(--azure) 0%, #1E3A8A 100%); border: none;">
        <div class="sb-title" style="color: rgba(255,255,255,0.85);">إجمالي الإيرادات ليوم العمل</div>
        <div class="sb-val" style="color: #ffffff; -webkit-text-fill-color: #ffffff;">
            @Model.TodayTotalCash.ToString("N2") <span style="font-size: 1rem; font-weight: 600; color: rgba(255,255,255,0.85); -webkit-text-fill-color: rgba(255,255,255,0.85);">ج.م</span>
        </div>
    </div>
</div>

<hr style="border-color: var(--glass-edge-blue); margin-bottom: 2rem;" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 style="font-weight: 800; color: var(--sapphire); margin-bottom: 0;">
        تفاصيل الجلسات المغلقة (@Model.ClosedSessions.Count)
    </h3>
</div>


<div class="table-glass-wrap">
    <table class="table-glass">
        <thead>
            <tr>
                <th>العميل</th>
                <th>رقم الهاتف</th>
                <th>وقت البداية</th>
                <th>وقت النهاية</th>
                <th class="text-center">مدة الجلسة</th>
                <th style="width: 25%;">المنتجات المطلوبة</th>
                <th>إجمالي الإيراد</th>
                <th class="text-center">إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.ClosedSessions.Any())
            {
                <tr>
                    <td colspan="8" class="text-center fw-bold py-4 text-muted">لا توجد جلسات مغلقة اليوم.</td>
                </tr>
            }
            @foreach (var session in Model.ClosedSessions)
            {
                <tr>
                    <td class="fw-bold text-sapphire">@session.CustomerName</td>
                    <td style="font-weight: 600;">@session.CustomerPhone</td>
                    <td dir="ltr" class="text-end">@session.StartTime.ToString("hh:mm tt")</td>
                    <td dir="ltr" class="text-end">@(session.EndTime?.ToString("hh:mm tt"))</td>

                    <td class="text-center" style="font-weight: 700; color: var(--text-slate);">
                        @if (session.EndTime.HasValue)
                        {
                            var duration = session.EndTime.Value - session.StartTime;
                            int h = (int)duration.TotalHours;
                            int m = duration.Minutes;
                            string timeDisplay = "";

                            if (h > 0 && m > 0) timeDisplay = $"{h} ساعة و {m} دقيقة";
                            else if (h > 0) timeDisplay = $"{h} ساعة";
                            else timeDisplay = $"{m} دقيقة";

                            @timeDisplay
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>

                    <td>
                        @if (session.ProductNames != null && session.ProductNames.Any())
                        {
                            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                @foreach (var product in session.ProductNames)
                                {
                                    <span style="background: var(--azure-glow-soft); padding: 4px 8px; border-radius: 6px; border: 1px solid var(--azure-glow); font-size: 0.85rem; color: var(--sapphire); font-weight: 700;">
                                        <bdi>@product</bdi>
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <span style="color: var(--text-slate); font-weight: 600;">-</span>
                        }
                    </td>

                    <td>
                        <span class="badge-glass" style="background: var(--sapphire); color: #ffffff; border: none; font-size: 0.9rem; padding: 6px 12px;">
                            @session.GrandTotal.ToString("N2") ج.م
                        </span>
                    </td>

                    <td class="text-center">
                        <form asp-controller="Session" asp-action="ReopenSession" asp-route-id="@session.SessionId" method="post" class="m-0 p-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm" style="background: rgba(255, 196, 0, 0.15); color: #C9631A; border: 1px solid #FFC400; font-weight: 700; border-radius: 6px; padding: 4px 10px; transition: all 0.2s ease;"
                                    onclick="return confirm('هل أنت متأكد من إعادة فتح هذه الجلسة؟ سيتم استكمال حساب الوقت لها.')"
                                    onmouseover="this.style.background='rgba(255, 196, 0, 0.3)'"
                                    onmouseout="this.style.background='rgba(255, 196, 0, 0.15)'">
                                تراجع وفتح
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
