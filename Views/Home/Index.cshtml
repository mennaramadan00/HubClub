@model HubClub.ViewModels.HomeIndexViewModel
@using HubClub.Models.Enums
@{
    ViewData["Title"] = "إدارة الجلسات";
}

<!-- شريط البحث الفاخر -->
<div class="mb-4" style="background: rgba(255, 255, 255, 0.6); padding: 1rem; border-radius: 12px; border: 1px solid var(--glass-edge-blue);">
    <form method="get" asp-action="Index" class="d-flex gap-2 align-items-center m-0">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
               class="premium-input m-0 flex-grow-1"
               placeholder="ابحث عن جلسة باسم العميل أو رقم الهاتف..." />

        <button type="submit" class="btn-aurelian-primary" style="white-space: nowrap; padding: 0.6rem 1.5rem;">
            بحث
        </button>

        <!-- زر الإلغاء يظهر فقط إذا كان هناك بحث نشط -->
        @if (ViewData["CurrentFilter"] != null && !string.IsNullOrEmpty(ViewData["CurrentFilter"].ToString()))
        {
            <a asp-action="Index" class="btn-aurelian-outline" style="white-space: nowrap; padding: 0.6rem 1.5rem;">إلغاء البحث</a>
        }
    </form>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 style="font-weight: 800; color: var(--sapphire); margin-bottom: 0;">
        جميع الجلسات المفتوحة (@Model.ActiveCustomersCount)
    </h3>

    <!-- مجموعة الأزرار مجمعة مع بعضها عشان التنسيق ميبُظش -->
    <div class="d-flex gap-3 align-items-center">
        <!-- زر إضافة ملاحظة سريع -->
        <a asp-controller="Notes" asp-action="Index" class="btn-aurelian-outline">
            الملاحظات
        </a>

        <!-- زر فتح جلسة جديدة الثابت في أعلى الشاشة -->
        <a asp-controller="Session" asp-action="Open" class="btn-aurelian-primary">
            بدء جلسة جديدة
        </a>
    </div>
</div>
@if (!Model.ActiveSessions.Any())
{
    <div class="glass-form-container text-center py-5 mt-4">
        <h3 style="color: var(--sapphire); font-weight: 800;">لا توجد جلسات حالياً</h3>
        <p style="color: var(--text-slate);">لم يتم العثور على نتائج، أو لا توجد جلسات مفتوحة.</p>
        <a asp-controller="Session" asp-action="Open" class="btn-aurelian-primary mt-3">بدء جلسة جديدة</a>
    </div>
}
else
{
    <!-- شبكة الجلسات بـ 3 أعمدة -->
    <div class="cards-grid-3">
        @foreach (var session in Model.ActiveSessions)
        {
            <div class="wf-card">
                <div class="wf-card-header text-center">
                    <h3 style="margin: 0; font-weight: 800; color: var(--sapphire);">@session.CustomerName</h3>
                </div>

                <div class="wf-data-row">
                    <span class="wf-data-label">رقم الهاتف</span>
                    <span class="wf-data-val">@session.CustomerPhone</span>
                </div>

                <div class="wf-data-row">
                    <span class="wf-data-label">نظام الدفع</span>
                    <span class="wf-data-val">@(session.PaymentType == PaymentType.Package ? "خصم من الباقة" : "دفع نقدي")</span>
                </div>

                <div class="wf-data-row">
                    <span class="wf-data-label">وقت البدء</span>
                    <span class="wf-data-val" dir="ltr">@session.StartTime.ToString("hh:mm tt")</span>
                </div>

                <div class="mt-3 mb-4 flex-grow-1">
                    <strong style="color: var(--sapphire); font-size: 0.95rem; display: block; margin-bottom: 0.5rem;">الطلبات الحالية:</strong>
                    <div style="font-size: 0.9rem; color: var(--text-slate); background: rgba(255, 255, 255, 0.6); padding: 0.8rem; border-radius: var(--radius-sharp); border: 1px solid var(--glass-edge-blue); min-height: 45px; text-align: center; font-weight: 600;">
                        @(session.ProductNames.Any() ? string.Join("، ", session.ProductNames) : "لا توجد طلبات حتى الآن")
                    </div>
                </div>

                <!-- أزرار الإجراءات: إضافة طلبات وإنهاء الجلسة -->
                <div class="mt-auto d-flex gap-2">
                    <a asp-controller="Session" asp-action="AddProducts" asp-route-id="@session.SessionId" class="btn-aurelian-primary" style="flex: 1; text-align: center; font-size: 0.9rem; padding: 0.6rem;">
                        إضافة طلبات
                    </a>
                    <a asp-controller="Session" asp-action="CloseReview" asp-route-id="@session.SessionId" class="btn-aurelian-outline" style="flex: 1; text-align: center; font-size: 0.9rem; padding: 0.6rem;">
                        إنهاء الجلسة
                    </a>
                </div>
            </div>
        }
    </div>
}