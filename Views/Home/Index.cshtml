@model HubClub.ViewModels.HomeIndexViewModel
@using HubClub.Models.Enums
@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container-fluid py-4" dir="rtl">

    <!-- رسالة النجاح -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 0.6rem;">
            <strong>✅ نجاح!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Header -->
    <div class="page-header">
        <div>
            <h1>🏠 لوحة التحكم</h1>
            <p>متابعة اليوم المحاسبي: @Model.BusinessDate.ToString("dd/MM/yyyy")</p>
        </div>
        <a asp-controller="Session" asp-action="Open" class="btn-add">
            ➕ جلسة جديدة
        </a>
    </div>

    <!-- Stats Bar (إحصائيات اليوم) -->
    <div class="stats-bar">
        <div class="stat-card">
            @* <div class="stat-icon blue">⏱️</div> *@
            <div>
                <div class="stat-label">إيرادات الوقت</div>
                <div class="stat-value">@Model.TodayTotalTimeCash.ToString("N2") ج</div>
            </div>
        </div>

        <div class="stat-card">
            @* <div class="stat-icon yellow">🛒</div> *@
            <div>
                <div class="stat-label">إيرادات البار</div>
                <div class="stat-value">@Model.TodayTotalProductCash.ToString("N2") ج</div>
            </div>
        </div>

        <div class="stat-card">
            @* <div class="stat-icon green">💰</div> *@
            <div>
                <div class="stat-label">الإجمالي الكلي</div>
                <div class="stat-value" style="color: var(--green-500);">@Model.TodayTotalCash.ToString("N2") ج</div>
            </div>
        </div>
    </div>

    <!-- Active Sessions (الجلسات الحالية) -->
    <h4 class="section-title" style="margin-top: 0; color: var(--yale-2);">🟢 الجلسات الحالية (@Model.ActiveCustomersCount)</h4>

    @if (!Model.ActiveSessions.Any())
    {
        <div class="empty-state" style="background: var(--white); border-radius: var(--r-xl); box-shadow: var(--shadow-sm); border: 1px solid var(--ink-100); margin-bottom: 2rem;">
            <div class="icon">🪑</div>
            <h3>المكان فارغ حالياً</h3>
            <p>لم يتم فتح أي جلسات حتى الآن في هذا اليوم المحاسبي.</p>
        </div>
    }
    else
    {
        <div class="products-grid mb-5">
            @foreach (var session in Model.ActiveSessions)
            {
                <div class="product-card">
                    <div class="card-top">
                        <span class="status-badge active" style="top: 1rem; left: auto; right: 1rem;"> قيد التشغيل</span>
                        <h3 class="product-name mt-4 pt-2">@session.CustomerName</h3>
                    </div>

                    <div class="card-body" style="flex-direction: column; align-items: stretch; gap: 0.5rem; padding-bottom: 0;">
                        <div class="info-row py-1">
                            <span class="info-key">وقت الدخول</span>
                            <span class="info-val">@session.StartTime.ToString("hh:mm tt")</span>
                        </div>

                        @if (session.ProductNames.Any())
                        {
                            <div class="mt-1 p-2 rounded" style="font-size: 0.85rem; background: var(--ink-50); border: 1px solid var(--ink-100);">
                                <strong>الطلبات:</strong> <span class="text-muted">@string.Join("، ", session.ProductNames)</span>
                            </div>
                        }
                    </div>

                    <div class="p-3">
                        <a asp-controller="Session" asp-action="CloseReview" asp-route-id="@session.SessionId" class="btn-save w-100 text-center text-decoration-none d-block" style="background: var(--air-force); box-shadow: none; color: var(--white);">
                            🏁 إغلاق ومحاسبة
                        </a>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Closed Sessions (الجلسات المنتهية) -->
    <h4 class="section-title" style="color: var(--ink-500);"> الجلسات المنتهية اليوم (@Model.ClosedSessions.Count)</h4>

    @if (Model.ClosedSessions.Any())
    {
        <div class="products-grid">
            @foreach (var session in Model.ClosedSessions)
            {
                <div class="product-card" style="opacity: 0.92; background: var(--ink-50);">
                    <div class="card-top" style="background: linear-gradient(135deg, var(--ink-500), var(--steel)); padding: 1rem 1.3rem;">
                        <h3 class="product-name m-0">@session.CustomerName</h3>
                    </div>
                    <div class="card-body" style="flex-direction: column; align-items: stretch;">
                        <div class="product-price mb-2" style="color: var(--green-500);">@session.GrandTotal.ToString("N2") <span>ج</span></div>
                        <small class="text-muted d-block mt-2">
                            <strong>من:</strong> @session.StartTime.ToString("hh:mm tt") <br />
                            <strong>إلى:</strong> @(session.EndTime?.ToString("hh:mm tt"))
                        </small>
                    </div>
                </div>
            }
        </div>
    }
</div>