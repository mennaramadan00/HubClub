@model HubClub.Models.Customer
@{
    ViewData["Title"] = "بيانات العميل";
}

<link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />

<div class="detail-page">
    <div class="detail-card">
        <div class="detail-hero">
            <div class="product-icon">👤</div>
            <h2>@Model.Name</h2>
            <div class="price-display">
                <span style="font-size: 1.2rem; color: var(--white);">📞 @Model.Phone</span>
            </div>
            <div>
                <span class="status-pill @(Model.IsActive ? "active" : "inactive")">
                    @(Model.IsActive ? "✓ حساب نشط" : "✗ حساب مؤرشف")
                </span>
            </div>
        </div>

        <div class="detail-body">
            <div class="info-row">
                <span class="info-key">📅 تاريخ التسجيل</span>
                <span class="info-val">@Model.CreatedAt.ToString("dd/MM/yyyy hh:mm tt")</span>
            </div>
        </div>

        <div class="detail-actions">
            <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn-edit">✏️ تعديل</a>
            <a asp-action="Delete" asp-route-id="@Model.CustomerId" class="btn-delete">🗑 حذف</a>
        </div>
        <div style="text-align: center; margin-bottom: 1rem;">
            <a asp-action="Index" class="btn-back" style="border: none; background: transparent;">← العودة للقائمة</a>
        </div>
    </div>
</div>