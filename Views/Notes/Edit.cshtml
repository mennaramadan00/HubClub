@model HubClub.Models.Note
@{
    ViewData["Title"] = "تعديل الملاحظة";
}

<div dir="rtl" class="glass-form-container">
    <div class="form-header">
        <h2>تعديل الملاحظة</h2>
        <p>تحديث بيانات الملاحظة المسجلة.</p>
    </div>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

        <input type="hidden" asp-for="NoteId" />
        <input type="hidden" asp-for="CreatedAt" /> <!-- إرسال التاريخ القديم مخفياً للحفاظ عليه -->

        <div class="form-group">
            <label asp-for="Title" class="premium-label">عنوان الملاحظة</label>
            <input asp-for="Title" class="premium-input" />
            <span asp-validation-for="Title" class="text-danger fw-bold" style="font-size: 0.85rem; display: block; margin-top: -1rem; margin-bottom: 1rem;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Content" class="premium-label">محتوى الملاحظة</label>
            <textarea asp-for="Content" class="premium-input" rows="5"></textarea>
            <span asp-validation-for="Content" class="text-danger fw-bold" style="font-size: 0.85rem; display: block; margin-top: -1rem; margin-bottom: 1rem;"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-aurelian-primary">حفظ التعديلات</button>
            <a asp-action="Index" class="btn-aurelian-outline">إلغاء وعودة</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}